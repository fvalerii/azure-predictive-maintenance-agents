# =============================================================================
# Foundry Hackathon — Environment Variables
# Fill in values from deploy.sh output
# =============================================================================

# Azure Subscription
AZURE_SUBSCRIPTION_ID=
RESOURCE_GROUP=foundry-hackathon-rg

# AI Foundry
FOUNDRY_RESOURCE_NAME=
PROJECT_NAME=tire-factory-project
FOUNDRY_ENDPOINT=
PROJECT_CONNECTION_STRING=
MODEL_DEPLOYMENT_NAME=gpt-5.4
# Optional deploy.sh overrides (GlobalStandard supports gpt-5.4)
# MODEL_NAME=gpt-5.4
# MODEL_VERSION=2026-03-05

# Application Insights & Monitoring
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPINSIGHTS_INSTRUMENTATION_KEY=

# Tracing (set to true to enable GenAI tracing)
AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true

# Challenge 4 — Portal Workflow (set after creating the workflow in Foundry portal)
# Build -> Workflows -> New workflow -> deploy -> copy the agent name here
WORKFLOW_AGENT_NAME=
